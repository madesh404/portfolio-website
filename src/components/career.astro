---
import careerData from '../data/career.json';
import CareerCard from './career-card.astro';

const sections = [
  { key: 'education', label: 'Education', data: careerData.education },
  { key: 'work',      label: 'Work',      data: careerData.work },
];
---

<section id="experience" class="section-container max-w-6xl mx-auto overflow-hidden">
  <div class="container mx-auto reveal-content" style="animation-delay: 1000ms;">
    <div>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Experience
      </h2>
      <p class="text-subtext font-body text-sm max-w-md pb-8">
        A brief overview of my education and work experience.
      </p>
    </div>

    {sections.map(({ key, label, data }) => (
      <div class="mb-16">
        <h3 class="text-xl font-heading font-semibold text-maintext mb-6 flex items-center gap-3">
          <span class="text-accent/60 text-sm">—</span> {label}
        </h3>

        {/* Mobile View */}
        <div class="md:hidden space-y-8 relative">
          <div class="absolute left-2 top-5 bottom-0 w-0.5 bg-linear-to-b from-accent via-white/10 to-transparent"></div>
          {data.map((item, index) => (
            <div class="scroll-stat relative pl-6">
              <div class="absolute left-0 top-1 z-10">
                <div class={`w-4 h-4 rounded-full border-4 border-[#0a0a0a]
                  ${index === 0 ? 'bg-accent shadow-[0_0_15px_var(--color-accent)] animate-pulse' : 'bg-accent/50'}`}>
                </div>
              </div>
              <CareerCard item={item} variant="mobile" />
            </div>
          ))}
        </div>

        {/* Desktop View */}
        <div class="hidden md:block space-y-4">
          {data.map((item) => (
            <div class="scroll-stat">
              <CareerCard item={item} variant="mobile" />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes revealIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .scroll-stat {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-stat.reveal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealCards() {
    const cards = document.querySelectorAll('.scroll-stat');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Array.from(cards).indexOf(entry.target);
          setTimeout(() => entry.target.classList.add('reveal'), (index % 3) * 150);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -10px 0px' });
    cards.forEach(card => observer.observe(card));
  }

  revealCards();
  document.addEventListener('astro:after-swap', revealCards);
</script>