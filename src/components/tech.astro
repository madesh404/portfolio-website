---
import { Icon } from 'astro-icon/components';
import localTechData from '../data/tech.json';

interface Skill {
  name: string;
  icon: string;
}

interface Category {
  title: string;
  skills: Skill[];
}

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
let categories: Category[];

try {
  if (BASE_URL) {
    const response = await fetch(`${BASE_URL}/tech`);
    const data = await response.json();
    categories = data.categories;
  } else {
    categories = localTechData.categories;
  }
} catch {
  categories = localTechData.categories;
}
---

<section id="skills" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="tech-header mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Skills
      </h2>
      <p class="text-subtext font-body text-sm max-w-md">
        Technologies and tools I work with.
      </p>
    </div>

    <div class="space-y-8">
      {categories.map((category) => (
        <div class="flex items-start gap-6">

          <div class="shrink-0 w-32 pt-3">
            <span class="text-maintext font-body text-[11px] uppercase tracking-[0.4em]">
              {category.title}
            </span>
          </div>

          <div class="flex flex-wrap gap-4">
            {category.skills.map((skill) => (
              <div class="skill-card opacity-0 group relative flex items-stretch min-h-14 rounded-xl bg-accent/5 border border-accent/15 hover:border-accent/40 hover:bg-accent/10 transition-all duration-300">
                <div class="shrink-0 w-12 flex items-center justify-center rounded-l-xl bg-accent/15 transition-colors group-hover:bg-accent/20">
                  <Icon name={skill.icon} class="w-7 h-7 group-hover:scale-110 transition-transform" />
                </div>
                <div class="flex items-center px-3 py-2">
                  <span class="font-body text-maintext/90 text-[13px] leading-tight font-medium tracking-tight">
                    {skill.name}
                  </span>
                </div>
              </div>
            ))}
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-header {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skill-card {
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tech-header.reveal,
  .skill-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealSkills() {
    const header = document.querySelector('.tech-header');
    const cards = document.querySelectorAll('.skill-card');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target;
          if (target.classList.contains('tech-header')) {
            target.classList.add('reveal');
            observer.unobserve(target);
          } else if (target.classList.contains('skill-card')) {
            const index = Array.from(cards).indexOf(target);
            setTimeout(() => target.classList.add('reveal'), (index % 6) * 50);
            observer.unobserve(target);
          }
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
  }

  revealSkills();
  document.addEventListener('astro:after-swap', revealSkills);
</script>